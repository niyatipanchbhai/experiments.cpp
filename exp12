#include<iostream>
using namespace std;
class shape 
{
    public :
    virtual void area()
    {
        cout <<"area of generic shape is unknown "<<endl;
    }
};
class rectangle : public shape 
{
    private : 
    float length , width ;
    public :
    rectangle (float l , float w)
    {
        length = l;
        width = w;
    }
    void area ()
    {
        cout <<"area of rectangle ="<< length *width << endl;

    }
};
class circle : public shape
{
    private:
    float radius ;
    public:
    circle(float r)
    {
        radius =r;
    }
    void area()
    {
        cout << "area of circle ="<< 3.1416*radius *radius<<endl;
    }
};
int main()
{
    shape*s1 , *s2;
    rectangle rect(10,5);
    circle circ(7);
    s1=&rect;
    s2=&circ;
    cout <<"virtual function demonstraction";
    s1->area();
    s2->area();
    return 0;
}    

